{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ckks-runtime/runtime-plan/v1/plaintext-bundle.schema.json",
  "title": "RuntimePlan V1 plaintext bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_format_version", "bundle_id", "version", "blobs"],
  "properties": {
    "bundle_format_version": { "const": 1 },
    "bundle_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "blobs": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["content", "byte_length"], "properties": { "content": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }, "byte_length": { "type": "integer", "minimum": 8, "maximum": 9007199254740991, "multipleOf": 8 } } } }
  }
}
